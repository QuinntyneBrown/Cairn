.vs/
.vscode/
.idea/
*.user
*.suo

# Local secrets. The JWT signing key must never be committed: appsettings.json ships it
# empty on purpose and the API refuses to start without one, so production has to supply
# its own via environment or user-secrets.
appsettings.Local.json
*.local.json
secrets.json

