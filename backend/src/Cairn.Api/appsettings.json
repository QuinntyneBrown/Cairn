{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Server=.\\SQLEXPRESS;Database=Cairn;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Cors": {
    // The Angular dev server is pinned to 4205, not Angular's default 4200 — see
    // frontend/playwright.config.ts for why. These must not drift apart.
    "AllowedOrigins": [ "http://localhost:4205", "https://localhost:4205" ]
  },
  "VoteLink": {
    "BaseUrl": "http://localhost:4205"
  },
  "Jwt": {
    "Issuer": "cairn",
    "Audience": "cairn",
    "SigningKey": "",
    "AccessTokenMinutes": 30,
    "VoteSessionMaxMinutes": 60
  }
}
