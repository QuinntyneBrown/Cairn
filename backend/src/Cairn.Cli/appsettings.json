{
  "ConnectionStrings": {
    "Default": "Server=.\\SQLEXPRESS;Database=Cairn;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "VoteLink": {
    // Must match the Angular dev server, which is pinned to 4205 rather than the default
    // 4200 — see frontend/playwright.config.ts. Set CAIRN_VoteLink__BaseUrl to override.
    "BaseUrl": "http://localhost:4205"
  },
  // The CLI never issues a token — it dispatches handlers in-process and its identity is the
  // connection string. This section exists only because JwtOptions binds eagerly through the
  // shared AddCairnInfrastructure registration. The key is a placeholder and signs nothing;
  // it is deliberately not a secret and must never be given a real value here.
  "Jwt": {
    "Issuer": "cairn",
    "Audience": "cairn",
    "SigningKey": "not-a-secret-the-cli-signs-nothing",
    "AccessTokenMinutes": 30,
    "VoteSessionMaxMinutes": 60
  }
}
